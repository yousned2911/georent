{
 "name": "Subscription Plan",
 "module": "Rent Pro",
 "doctype": "DocType",
 "document_type": "Document",
 "autoname": "field:plan_name",
 "title_field": "plan_name",
 "search_fields": "plan_name,plan_label",
 "istable": 0,
 "editable_grid": 0,
 "track_changes": 1,
 "engine": "InnoDB",
 "fields": [
  {
   "fieldname": "section_plan",
   "fieldtype": "Section Break",
   "label": "Plan Details"
  },
  {
   "fieldname": "plan_name",
   "fieldtype": "Data",
   "label": "Plan Name",
   "reqd": 1,
   "unique": 1,
   "bold": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "plan_label",
   "fieldtype": "Data",
   "label": "Display Label",
   "reqd": 1
  },
  {
   "fieldname": "plan_type",
   "fieldtype": "Select",
   "label": "Plan Type",
   "options": "Starter\nProfessional\nEnterprise",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "column_plan",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "is_active",
   "fieldtype": "Check",
   "label": "Active",
   "default": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "is_trial",
   "fieldtype": "Check",
   "label": "Trial Plan",
   "default": 0,
   "description": "Free trial with no billing"
  },
  {
   "fieldname": "billing_cycle",
   "fieldtype": "Select",
   "label": "Billing Cycle",
   "options": "Monthly\nYearly",
   "default": "Monthly",
   "reqd": 1
  },
  {
   "fieldname": "section_pricing",
   "fieldtype": "Section Break",
   "label": "Pricing"
  },
  {
   "fieldname": "price_mad",
   "fieldtype": "Currency",
   "label": "Price (MAD)",
   "options": "MAD",
   "reqd": 1,
   "bold": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "price_yearly_mad",
   "fieldtype": "Currency",
   "label": "Yearly Price (MAD)",
   "options": "MAD",
   "description": "Discounted yearly price"
  },
  {
   "fieldname": "column_pricing",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "trial_days",
   "fieldtype": "Int",
   "label": "Trial Days",
   "default": 14,
   "description": "Days before billing starts"
  },
  {
   "fieldname": "currency",
   "fieldtype": "Link",
   "label": "Currency",
   "options": "Currency",
   "default": "MAD"
  },
  {
   "fieldname": "section_limits",
   "fieldtype": "Section Break",
   "label": "Usage Limits"
  },
  {
   "fieldname": "max_vehicles",
   "fieldtype": "Int",
   "label": "Maximum Vehicles",
   "default": 10,
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "max_users",
   "fieldtype": "Int",
   "label": "Maximum Users",
   "default": 3,
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "max_storage_mb",
   "fieldtype": "Int",
   "label": "Maximum Storage (MB)",
   "default": 1024
  },
  {
   "fieldname": "column_limits",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "max_ocr_per_month",
   "fieldtype": "Int",
   "label": "OCR Scans/Month",
   "default": 50
  },
  {
   "fieldname": "max_api_calls_per_month",
   "fieldtype": "Int",
   "label": "API Calls/Month",
   "default": 1000
  },
  {
   "fieldname": "geofleete_included",
   "fieldtype": "Check",
   "label": "GeoFleete Included",
   "default": 0,
   "in_list_view": 1
  },
  {
   "fieldname": "section_features",
   "fieldtype": "Section Break",
   "label": "Feature Access",
   "collapsible": 1
  },
  {
   "fieldname": "ocr_enabled",
   "fieldtype": "Check",
   "label": "OCR Enabled",
   "default": 1
  },
  {
   "fieldname": "geofleete_enabled",
   "fieldtype": "Check",
   "label": "GeoFleete Enabled",
   "default": 0
  },
  {
   "fieldname": "advanced_reports",
   "fieldtype": "Check",
   "label": "Advanced Reports",
   "default": 0
  },
  {
   "fieldname": "api_access",
   "fieldtype": "Check",
   "label": "API Access",
   "default": 0
  },
  {
   "fieldname": "column_features",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "white_label",
   "fieldtype": "Check",
   "label": "White Label",
   "default": 0,
   "description": "Custom branding and domain"
  },
  {
   "fieldname": "priority_support",
   "fieldtype": "Check",
   "label": "Priority Support",
   "default": 0
  },
  {
   "fieldname": "multi_branch",
   "fieldtype": "Check",
   "label": "Multi-Branch",
   "default": 0,
   "description": "Multiple office locations"
  },
  {
   "fieldname": "section_description",
   "fieldtype": "Section Break",
   "label": "Description",
   "collapsible": 1
  },
  {
   "fieldname": "description",
   "fieldtype": "Small Text",
   "label": "Plan Description"
  },
  {
   "fieldname": "features_list",
   "fieldtype": "Small Text",
   "label": "Features (one per line)"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1
  },
  {
   "role": "Rent Pro Manager",
   "read": 1,
   "write": 1,
   "create": 0,
   "delete": 0
  }
 ],
 "sort_field": "creation",
 "sort_order": "ASC"
}
