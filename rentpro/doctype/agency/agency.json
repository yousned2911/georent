 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "report": 1,
   "export": 1
  },
  {
   "role": "Rent Pro Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 0,
   "report": 1,
   "export": 1
  }
 ],
