{
 "name": "Agency",
 "module": "Rent Pro",
 "doctype": "DocType",
 "document_type": "Document",
 "autoname": "AGC-{####}",
 "title_field": "agency_name",
 "search_fields": "agency_name,city,contact_email",
 "istable": 0,
 "editable_grid": 0,
 "track_changes": 1,
 "engine": "InnoDB",
 "fields": [
  {
