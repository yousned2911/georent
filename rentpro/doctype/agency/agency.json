   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1,
   "bold": 1
  },
  {
   "fieldname": "subscription_plan",
   "fieldtype": "Link",
   "label": "Subscription Plan",
   "options": "Subscription Plan",
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "section_contact",
   "fieldtype": "Section Break",
   "label": "Contact & Address"
