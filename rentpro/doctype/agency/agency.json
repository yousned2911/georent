   "fieldtype": "Data",
   "label": "Contact Person",
   "reqd": 1
  },
  {
   "fieldname": "contact_email",
   "fieldtype": "Data",
   "label": "Email",
   "options": "Email",
   "reqd": 1
  },
  {
   "fieldname": "contact_phone",
   "fieldtype": "Data",
   "label": "Phone",
   "options": "Phone"
