{
  "name": "Vehicle Category",
  "module": "Rent Pro",
  "doctype": "DocType",
  "document_type": "Document",
  "issingle": 0,
  "istable": 0,
  "editable_grid": 0,
  "track_changes": 1,
  "engine": "InnoDB",
  "autoname": "field:category_name",
  "fields": [
    {
      "fieldname": "category_name",
      "fieldtype": "Data",
      "label": "Category Name",
      "reqd": 1,
      "unique": 1,
      "bold": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "daily_rate_multiplier",
      "fieldtype": "Float",
      "label": "Daily Rate Multiplier",
      "reqd": 1,
      "default": "1.0",
      "in_list_view": 1,
      "description": "Multiplied by base daily rate"
    },
    {
      "fieldname": "section_break_description",
      "fieldtype": "Section Break",
      "label": "Details"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "column_break_desc",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "security_deposit",
      "fieldtype": "Currency",
      "label": "Security Deposit",
      "options": "default_currency",
      "default": "0"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": "1",
      "in_list_view": 1
    }
  ],
  "permissions": [
    {
      "role": "Rent Pro Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Rent Pro User",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Rent Pro Read Only",
      "read": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC",
  "title_field": "category_name",
  "search_fields": "category_name"
}
