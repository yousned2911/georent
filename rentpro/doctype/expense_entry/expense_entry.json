{
 "name": "Expense Entry",
 "module": "Rent Pro",
 "doctype": "DocType",
 "document_type": "Document",
 "autoname": "EXP-{#####}",
 "title_field": "expense_number",
 "subject_field": "category",
 "search_fields": "expense_number,category,vehicle",
 "istable": 0,
 "editable_grid": 0,
 "track_changes": 1,
 "track_seen": 1,
 "engine": "InnoDB",
 "fields": [
  {
   "fieldname": "section_core",
   "fieldtype": "Section Break",
   "label": "Expense Details"
  },
  {
   "fieldname": "expense_number",
   "fieldtype": "Data",
   "label": "Expense Number",
   "reqd": 0,
   "read_only": 1,
   "unique": 1,
   "in_list_view": 1,
   "in_standard_filter": 1,
   "bold": 1
  },
  {
   "fieldname": "category",
   "fieldtype": "Select",
   "label": "Category",
   "options": "Fuel\nMaintenance\nInsurance\nTechnical Inspection\nRegistration\nCleaning\nRepairs\nTaxes\nMiscellaneous",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "amount",
   "fieldtype": "Currency",
   "label": "Amount",
   "options": "MAD",
   "reqd": 1,
   "in_list_view": 1,
   "bold": 1
  },
  {
   "fieldname": "column_vehicle",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "vehicle",
   "fieldtype": "Link",
   "label": "Vehicle",
   "options": "Vehicle",
   "reqd": 0,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "expense_date",
   "fieldtype": "Date",
   "label": "Expense Date",
   "reqd": 1,
   "default": "Today",
   "in_list_view": 1
  },
  {
   "fieldname": "section_additional",
   "fieldtype": "Section Break",
   "label": "Additional Information",
   "collapsible": 1
  },
  {
   "fieldname": "supplier",
   "fieldtype": "Data",
   "label": "Supplier"
  },
  {
   "fieldname": "notes",
   "fieldtype": "Small Text",
   "label": "Notes"
  },
  {
   "fieldname": "attachment",
   "fieldtype": "Attach",
   "label": "Receipt / Invoice"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "report": 1,
   "export": 1
  },
  {
   "role": "Rent Pro Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "report": 1,
   "export": 1
  },
  {
   "role": "Rent Pro Finance",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 0,
   "report": 1,
   "export": 1
  },
  {
   "role": "Rent Pro Fleet Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 0,
   "report": 0,
   "export": 0
  }
 ],
 "sort_field": "creation",
 "sort_order": "DESC"
}
